# Shared Python environment
venv/
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Local inputs and generated outputs
models/*
!models/.gitkeep
!models/README.txt
!models/put_your_ply_files_here.txt

output/*
!output/.gitkeep
!output/renderer/
!output/renderer/.gitkeep
!output/segmenter/
!output/segmenter/.gitkeep

# Old/local segmentation output location is deprecated
"segmentation tool"/outputs/

# Rendered/segmented images should not be committed by default
*.png
*.jpg
*.jpeg
*.webp

# Large 3D files should be added intentionally only
*.ply
!models/example*.ply

# Logs / temporary reports
errors.csv
*.log

# OS / editor
Thumbs.db
.DS_Store
.vscode/
.idea/
